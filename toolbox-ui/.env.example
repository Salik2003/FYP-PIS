# PISync Frontend — Environment Variables
# Copy this file to .env.local for local dev, or set these in Vercel dashboard for production.

# Engine backend (toolbox-engine-be-main) — Railway URL
# Local default: http://localhost:3000/api  (axiosClient.ts fallback)
VITE_API_URL=https://your-engine-service.up.railway.app/api

# Shopify API on engine backend
# Local default: http://localhost:3000/api/shopify-api  (shopifyService.ts fallback)
VITE_SHOPIFY_API_URL=https://your-engine-service.up.railway.app/api/shopify-api

# Odoo connector (toolbox-ds-odoo-babylon-main) — Railway URL
# Local default: http://localhost:3002/api/odoo  (odooService.ts fallback)
VITE_ODOO_API_URL=https://your-odoo-connector.up.railway.app/api/odoo
